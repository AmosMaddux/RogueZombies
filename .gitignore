# --- Godot 4 Core ---
# This folder contains the heavy, platform-specific metadata and import cache.
# DO NOT SYNC THIS. Pushing this is the #1 cause of tablet/PC conflicts.
.godot/

# --- Imported Assets ---
# Godot recreates these .import files automatically when it sees your raw assets.
*.import

# --- Export & Builds ---
# Keeps your binaries and presets out of the repo.
export_presets.cfg
builds/
*.exe
*.apk
*.ipa
*.wasm
*.pck

# --- C# / Mono / .NET (Optional but recommended) ---
# If you use C#, these folders are generated by the compiler.
.mono/
bin/
obj/
.csproj
.sln

# --- Editor & OS Junk ---
# Prevents desktop settings from cluttering your project.
.vsc/
.vscode/
.idea/
.DS_Store
Thumbs.db
*.tmp

# --- Crash Logs & Internal ---
*.log

# --- Android Files ---
/android/


